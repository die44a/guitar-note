<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GuitarNote.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:GuitarNote.Views"
        mc:Ignorable="d"
        x:Class="GuitarNote.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Icons/avalonia-logo.ico"
        Title="Guitar Note"
        
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Background="#121212"
        Width="900"
        Height="600"
        MinWidth="600"
        MinHeight="500"
        WindowStartupLocation="CenterScreen">
    
    <Window.Styles>
        <Styles>
            <StyleInclude Source="avares://GuitarNote/Assets/Styles/MainWindowStyles.axaml"/>
        </Styles>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- Main grid -->
    <Grid RowDefinitions="Auto,*">

        <!-- Custom title bar -->
        <local:TitleBar Name="TitleBar" 
                        Grid.Row="0"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"
                                  MinWidth="150"
                                  MaxWidth="500"/>  
                <ColumnDefinition Width="2"/>    
                <ColumnDefinition Width="*"/>    
            </Grid.ColumnDefinitions>

            <!-- Left panel -->
            <local:ControlPanel Grid.Column="0"/>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Background="Transparent"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="False"
                          Width="2"
                          HorizontalAlignment="Stretch"/>

            <!-- Right side -->
            <Grid Grid.Column="2" Margin="20" RowDefinitions="Auto,*">
                <Border Height="40"
                        Background="#1E1E1E"
                        CornerRadius="6"
                        Margin="0,0,0,10"/>

                <Border Grid.Row="1"
                        Background="#1A1A1A"
                        CornerRadius="6"
                        BorderBrush="#333333"
                        BorderThickness="1">
                    <Grid Margin="10">
                        <Border Height="4"
                                Width="60"
                                Background="#333333"
                                CornerRadius="2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
