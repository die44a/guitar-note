<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GuitarNote.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:GuitarNote.Views"
        mc:Ignorable="d"
        x:Class="GuitarNote.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Icons/avalonia-logo.ico"
        Title="Guitar Note"
        
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Background="#121212"
        Width="900"
        Height="600"
        MinWidth="600"
        MinHeight="450"
        WindowStartupLocation="CenterScreen">
    
    <Window.Styles>
        <Styles>
            <StyleInclude Source="avares://GuitarNote/Assets/Styles/MainWindowStyles.axaml"/>
        </Styles>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- Main grid -->
    <Grid RowDefinitions="Auto,*">

        <!-- Custom title bar -->
        <local:TitleBar Name="TitleBar" Grid.Row="0"/>

        <!-- Main interface -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>   <!-- Левая панель -->
                <ColumnDefinition Width="*"/>    <!-- Контент -->
            </Grid.ColumnDefinitions>

            <!-- Left panel -->
            <Border Grid.Column="0" Background="#1E1E1E">
                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Upper block -->
                    <Border Height="80"
                            Margin="0,10"
                            Background="#2A2A2A"
                            CornerRadius="6"/>

                    <!-- Menu buttons -->
                    <StackPanel Grid.Row="1" Spacing="10" Margin="10,0">
                        <Border Height="40" Background="#333333" CornerRadius="6"/>
                        <Border Height="40" Background="#333333" CornerRadius="6"/>
                        <Border Height="40" Background="#333333" CornerRadius="6"/>
                    </StackPanel>

                    <!-- Lower block -->
                    <Border Grid.Row="2"
                            Height="40"
                            Margin="10"
                            Background="#333333"
                            CornerRadius="6"/>
                </Grid>
            </Border>

            <!-- Right size -->
            <Grid Grid.Column="1" Margin="20" RowDefinitions="Auto,*">

                <!-- Instruction block -->
                <Border Height="40"
                        Background="#1E1E1E"
                        CornerRadius="6"
                        Margin="0,0,0,10"/>

                <!-- Text field -->
                <Border Grid.Row="1"
                        Background="#1A1A1A"
                        CornerRadius="6"
                        BorderBrush="#333333"
                        BorderThickness="1">
                    <Grid Margin="10">
                        <!-- Textfield filler -->
                        <Border Height="4"
                                Width="60"
                                Background="#333333"
                                CornerRadius="2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
