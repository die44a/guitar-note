<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="GuitarNote.Views.TextField"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">
    
    <UserControl.Styles>
        <Styles>
            <StyleInclude Source="avares://GuitarNote/Assets/Styles/TextFieldStyles.axaml"/>
        </Styles>
    </UserControl.Styles>
    
    <Grid Margin="20" RowDefinitions="Auto,*">
        
        <!-- Hint -->
        <Border Height="40"
                Background="#1E1E1E"
                CornerRadius="6"
                Margin="0,0,0,10"/>

        <!-- TextBox -->
        <Border Grid.Row="1"
                Background="#1A1A1A"
                CornerRadius="6"
                BorderBrush="#333333"
                BorderThickness="1">
            <Border Grid.Row="1"
                    Background="#1A1A1A"
                    CornerRadius="6"
                    BorderBrush="#333333"
                    BorderThickness="1">

                <TextBox
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
                    Background="#1A1A1A"
                    BorderThickness="0"
                    Margin="10"/>
            </Border>
        </Border>
    </Grid>
</UserControl>
