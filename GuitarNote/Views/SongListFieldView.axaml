<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GuitarNote.Views.SongListFieldView"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Styles>
        <Styles>
            <StyleInclude Source="avares://GuitarNote/Assets/Styles/SongListFieldStyles.axaml"/>
        </Styles>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*"
          RowSpacing="10"
          Margin="20">

        <!-- Header -->
        <Border Background="#1E1E1E"
                CornerRadius="6"
                Padding="10">
            <TextBlock Text="Песни"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#CCCCCC"
                       FontSize="16"/>
        </Border>

        <!-- Main block -->
        <Border Grid.Row="1"
                Background="#1A1A1A"
                CornerRadius="6"
                BorderBrush="#333333"
                BorderThickness="1"
                Padding="20">

            <Grid RowDefinitions="Auto,*"
                  RowSpacing="15">

                <!-- Top filter bar -->
                <Grid ColumnDefinitions="*,Auto"
                      VerticalAlignment="Center">

                    <!-- Dropdown imitation -->
                    <Border Background="#2A2A2A"
                            CornerRadius="4"
                            Padding="8,4"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Все песни"
                                       Foreground="#CCCCCC"
                                       FontSize="14"/>
                            <Path Data="M 0 0 L 8 0 L 4 5 Z"
                                  Fill="#CCCCCC"
                                  Width="8"
                                  Height="5"
                                  VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Menu icon -->
                    <Border Grid.Column="1"
                            Background="#2A2A2A"
                            CornerRadius="4"
                            Padding="6"
                            HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <Ellipse Width="4" Height="4" Fill="#CCCCCC"/>
                            <Ellipse Width="4" Height="4" Fill="#CCCCCC"/>
                            <Ellipse Width="4" Height="4" Fill="#CCCCCC"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Song list -->
                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="8">

                        <!-- Example items -->
                        <Border Background="#2A2A2A"
                                CornerRadius="4"
                                Padding="10">
                            <TextBlock Text="Мои песни"
                                       Foreground="#FFFFFF"
                                       FontSize="14"/>
                        </Border>

                        <Border Background="#2A2A2A"
                                CornerRadius="4"
                                Padding="10">
                            <TextBlock Text="Популярные"
                                       Foreground="#FFFFFF"
                                       FontSize="14"/>
                        </Border>

                        <Border Background="#2A2A2A"
                                CornerRadius="4"
                                Padding="10">
                            <TextBlock Text="Избранное"
                                       Foreground="#FFFFFF"
                                       FontSize="14"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Border>
    </Grid>
</UserControl>
