<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GuitarNote.App"
             xmlns:local="using:GuitarNote"
             xmlns:viewModels="clr-namespace:GuitarNote.ViewModels"
             xmlns:views="clr-namespace:GuitarNote.Views"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
        <DataTemplate DataType="viewModels:TextFieldViewModel">
            <views:TextFieldView/>
        </DataTemplate>

        <DataTemplate DataType="viewModels:TunerFieldViewModel">
            <views:TunerFieldView/>
        </DataTemplate>

        <DataTemplate DataType="viewModels:SongListFieldViewModel">
            <views:SongListFieldView/>
        </DataTemplate>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
             
</Application>